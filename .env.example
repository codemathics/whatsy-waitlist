# Copy to .env.local in this directory (website/) and add your keys.
# Next.js loads .env.local from the app root (website/ when you run npm run dev).

# Notion waitlist storage (required)
NOTION_API_KEY=
NOTION_WAITLIST_DATABASE_ID=

# Optional confirmation email via Resend
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=

# Optional analytics
NEXT_PUBLIC_MICROSOFT_CLARITY_ID=
