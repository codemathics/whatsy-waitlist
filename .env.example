# copy to .env.local in this directory (website/).
# next.js loads .env.local from the app root when you run npm run dev.

# notion waitlist storage (required)
NOTION_API_KEY=
NOTION_WAITLIST_DATABASE_ID=

# optional confirmation email via resend
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=

# optional analytics
NEXT_PUBLIC_MICROSOFT_CLARITY_ID=

# story video (avoids youtube sign-in / third-party restrictions)
# option a – cloudflare r2 (recommended, no egress fees): create bucket, enable public url, upload, then:
# STORY_VIDEO_URL=https://pub-xxx.r2.dev/backstory.mp4
# option b – local mp4: put video in public/videos/
# STORY_VIDEO_URL=/videos/backstory.mp4
# option c – vimeo
# NEXT_PUBLIC_STORY_VIDEO_PROVIDER=vimeo
# NEXT_PUBLIC_STORY_VIDEO_ID=
